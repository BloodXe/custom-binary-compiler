# Test: Eliminación de Código Muerto (DCE)
# Las variables basura no llegan a ningún save()
# El DCE con CFG las debe eliminar completamente

var total_operaciones : int = 0'

func multiplicar(a : int, b : int) :: int {
    var res : int = 0'
    var i : int = 0'
    para (i = 0' i < b' i = i + 1') {
        res = res + a'
    }
    retorna res'
}

func calcular(a : int, b : int) :: int {
    # Código muerto — no llega a save
    var temporal : int = a * 100'
    var basura1  : int = a + b'

    # Cálculo real
    var suma : int = 0'
    suma = multiplicar(a, b)'
    total_operaciones = total_operaciones + 1'

    # Más código muerto
    var basura2 : int = suma * 999'
    var basura3 : int = basura2 + 1'

    retorna suma'
}

func main() :: void {
    var c00 : int = 0'
    var c01 : int = 0'

    c00 = calcular(3, 4)'
    c01 = calcular(2, 5)'

    # Código muerto global
    var estadistica : int = total_operaciones'
    var desperdicio : int = estadistica * 2'

    save(c00)'
    save(c01)'
    save(total_operaciones)'
}
