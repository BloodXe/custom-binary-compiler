# Test: Loop Unrolling
# Array de 4 elementos con tamaño fijo
# El compilador desenrolla el loop para reducir
# el overhead de condición e incremento

var total : int = 0'
var len : int = 4'
var res : int = 0'
var bloque : [4]int = [10, 20, 30, 40]'
var i : int = 0'

func procesar() :: void {

    para (i = 0' i < len' i = i + 1') {
        res = res + bloque[i] * 2'
    }

    total = res'
    save(total)'
}

func main() :: void {
    procesar()'
    save(total)'
}