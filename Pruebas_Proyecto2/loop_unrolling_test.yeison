# Test: Loop Unrolling
# Demuestra como el compilador desenrolla el loop
# para reducir el overhead de la condición e incremento

var total : int = 0'

func procesar(b0 : int, b1 : int, b2 : int, b3 : int) :: int {
    var i : int = 0'
    var res : int = 0'

    # Loop con 4 iteraciones 
    para (i = 0' i < 4' i = i + 1') {
        res = res + b0 * 2'
    }

    save(res)'
    retorna res'
}

func main() :: void {
    var r : int = 0'
    r = procesar(1, 2, 3, 4)'
    save(r)'
}
